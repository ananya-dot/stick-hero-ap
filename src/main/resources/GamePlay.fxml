<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane fx:id="gamePlayRoot" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.GamePlayController">
   <children>
      <ImageView fx:id="gameBackGround" fitHeight="400.0" fitWidth="600.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@images/img_2.png" />
         </image>
      </ImageView>
      <ImageView fx:id="pauseButton" fitHeight="47.0" fitWidth="48.0" layoutX="540.0" layoutY="12.0" onMouseClicked="#switchToPauseMenu" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@images/pauseButton.png" />
         </image>
      </ImageView>
      <ImageView fx:id="harry" fitHeight="108.0" fitWidth="47.0" layoutX="-1.0" layoutY="152.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@images/harryWalk1.png" />
         </image>
      </ImageView>
      <Line fx:id="stick" endX="14.0" layoutX="42.0" layoutY="243.0" startX="14.0" stroke="WHITE" strokeWidth="3.0" />
      <Button fx:id="growButton" layoutX="269.0" layoutY="59.0" mnemonicParsing="false" onMousePressed="#grow" onMouseReleased="#stopGrowing" text="grow" />
      <Rectangle fx:id="pillar1" arcHeight="5.0" arcWidth="5.0" fill="#b08161" height="160.0" layoutX="-1.0" layoutY="240.0" stroke="BLACK" strokeType="INSIDE" width="60.0" />
      <Rectangle fx:id="pillar2" arcHeight="5.0" arcWidth="5.0" fill="#b08161" height="160.0" layoutX="168.0" layoutY="240.0" stroke="BLACK" strokeType="INSIDE" width="70.0" />
   </children>
</AnchorPane>
