<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Line?>

<AnchorPane fx:id="gamePlayRoot" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.GamePlayController">
   <children>
      <ImageView fx:id="gameBackGround" fitHeight="400.0" fitWidth="600.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@images/gamePlayBG.png" />
         </image>
      </ImageView>
      <ImageView fx:id="pauseButton" fitHeight="47.0" fitWidth="48.0" layoutX="540.0" layoutY="12.0" onMouseClicked="#switchToPauseMenu" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@images/pauseButton.png" />
         </image>
      </ImageView>
      <ImageView fx:id="harry" fitHeight="108.0" fitWidth="47.0" layoutX="7.0" layoutY="152.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@images/harryWalk1.png" />
         </image>
      </ImageView>
      <Line fx:id="stick" endX="-100.0" endY="-22.0" layoutX="155.0" layoutY="241.0" startX="-100.0" stroke="#f8f6f6" strokeWidth="3.0" />
      <Button layoutX="272.0" layoutY="260.0" mnemonicParsing="false"  onMousePressed="#onMousePressed" onMouseReleased="#grow" text="grow" />
   </children>
</AnchorPane>
