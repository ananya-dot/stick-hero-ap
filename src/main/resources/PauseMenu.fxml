<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.effect.Blend?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.SceneController">
   <children>
      <ImageView fitHeight="423.0" fitWidth="600.0" layoutY="-4.0" pickOnBounds="true">
         <image>
            <Image url="@images/PauseBackground.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="43.0" fitWidth="153.0" layoutX="248.0" layoutY="64.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@images/pauseMenuText.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="43.0" fitWidth="162.0" layoutX="226.0" layoutY="133.0" onMouseClicked="#switchToGamePlay" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@images/PauseMenu-Resume.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="42.0" fitWidth="147.0" layoutX="227.0" layoutY="190.0" onMouseClicked="#switchToGamePlay" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@images/PauseMenu-RestartLevel.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="43.0" fitWidth="162.0" layoutX="227.0" layoutY="248.0" onMouseClicked="#switchToMain" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@images/PauseMenu-SaveGame.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="43.0" fitWidth="90.0" layoutX="256.0" layoutY="310.0" onMouseClicked="#exit" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@images/PauseMenu-Exit.png" />
         </image>
      </ImageView>
   </children>
   <opaqueInsets>
      <Insets />
   </opaqueInsets>
   <effect>
      <Blend />
   </effect>
</AnchorPane>
